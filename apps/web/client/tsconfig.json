{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@sonora/contracts": ["../../../packages/contracts/src/index.ts"],
      "@sonora/ui": ["../../../packages/ui/src/index.ts"],
      "@sonora/features": ["../../../packages/features/src/index.ts"],
      "@sonora/admin": ["../../../packages/admin/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
